generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  MANAGER
}

enum CandidateStatus {
  APPLIED
  SCREENING
  AI_INTERVIEW
  TECH_INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewMode {
  CHAT
  VOICE
}

enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(HR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vacancies  Vacancy[]
  candidates Candidate[]
}

model Vacancy {
  id          String   @id @default(cuid())
  title       String
  department  String?
  grade       String?
  stack       String[]
  location    String?
  salaryMin   Int?
  salaryMax   Int?
  description String?
  duties      String?
  requirements String?
  conditions  String?
  hhVersion   String?
  linkedinVersion String?
  telegramVersion String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String

  candidates Candidate[]

  @@index([isActive])
}

model Candidate {
  id        String          @id @default(cuid())
  name      String
  email     String?
  phone     String?
  telegram  String?
  resume    String?
  status    CandidateStatus @default(APPLIED)
  aiScore   Float?
  notes     String?
  stageEnteredAt DateTime  @default(now())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  vacancy   Vacancy @relation(fields: [vacancyId], references: [id])
  vacancyId String

  addedBy   User   @relation(fields: [addedById], references: [id])
  addedById String

  interviews Interview[]
  history    CandidateHistory[]

  @@index([vacancyId, status])
}

model CandidateHistory {
  id         String          @id @default(cuid())
  fromStatus CandidateStatus?
  toStatus   CandidateStatus
  comment    String?
  changedAt  DateTime        @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String
}

model Interview {
  id        String          @id @default(cuid())
  mode      InterviewMode   @default(CHAT)
  status    InterviewStatus @default(PENDING)
  token     String          @unique @default(cuid())
  questions Json?
  answers   Json?
  score     Float?
  strengths String[]
  risks     String[]
  recommendation String?
  expiresAt DateTime
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime        @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String
}

model SalaryDataPoint {
  id        String   @id @default(cuid())
  title     String
  grade     String?
  salaryMin Int?
  salaryMax Int?
  location  String?
  company   String?
  source    String
  skills    String[]
  parsedAt  DateTime @default(now())

  @@index([title, location])
}

model SlaConfig {
  id       String          @id @default(cuid())
  stage    CandidateStatus
  maxHours Int             @default(72)
}
